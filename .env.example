DATABASE_URL="file:./db/custom.db"

# Google Gemini API key — used by the admin dashboard to draft product
# descriptions. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Admin dashboard login (single account, no signup flow)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# NextAuth session secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
