# Production database. Use a Postgres URL from Neon, Supabase, Prisma Postgres,
# or Vercel storage. SQLite is not suitable for hosted ecommerce orders.
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/database?sslmode=require"

# Google Gemini API key — used by the admin dashboard to draft product
# descriptions. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Admin dashboard login (single account, no signup flow)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-me"

# NextAuth session secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Public base URL used for Mollie redirect/webhook URLs. In local dev, webhooks
# can't reach localhost — use a tunnel (e.g. ngrok) and put its https URL here.
# Leave blank to derive the origin from the request.
PUBLIC_BASE_URL=""

# Vercel Blob — stores customer-uploaded 3D models in production. Not needed
# for local dev (uploads fall back to public/uploads on disk). On Vercel,
# create a Blob store and this is injected automatically.
BLOB_READ_WRITE_TOKEN=""

# Mollie — payments (use your test_… key while testing)
MOLLIE_API_KEY=""

# Sendcloud — shipping labels (admin)
SENDCLOUD_PUBLIC_KEY=""
SENDCLOUD_SECRET_KEY=""
SENDCLOUD_SHIPPING_METHOD_ID=""
SENDCLOUD_FROM_NAME="Your Studio"
SENDCLOUD_FROM_COMPANY="Your Studio"
SENDCLOUD_FROM_ADDRESS=""
SENDCLOUD_FROM_HOUSE_NUMBER=""
SENDCLOUD_FROM_CITY=""
SENDCLOUD_FROM_POSTAL_CODE=""
SENDCLOUD_FROM_COUNTRY="BE"
