// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  projectType String
  quantity    String?
  budget      String?
  message     String
  fileUrl     String?
  createdAt   DateTime @default(now())
}

model Order {
  id          String      @id @default(cuid())
  ref         String      @unique
  email       String
  name        String
  address     String
  houseNumber String?
  city        String
  postalCode  String
  country     String
  total       Float
  // pending_payment | paid | processing | shipped | delivered | cancelled | failed | expired
  status      String      @default("pending_payment")
  locale      String      @default("en")
  items       OrderItem[]

  // Payment (Mollie)
  paymentId     String?
  paymentStatus String?
  paidAt        DateTime?

  // Shipping (Sendcloud)
  shippingMethod    String?
  sendcloudParcelId String?
  trackingNumber    String?
  trackingUrl       String?
  labelUrl          String?

  createdAt   DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  productId String
  name      String
  price     Float
  qty       Int
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  price       Float
  category    String
  image       String
  badge       String?
  stock       Int      @default(0)
  material    Json
  dimensions  String
  layerHeight String
  finishing   Json
  name        Json
  description Json
  modelUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
