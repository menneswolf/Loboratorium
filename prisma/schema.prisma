// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  projectType String
  quantity    String?
  budget      String?
  message     String
  fileUrl     String?
  createdAt   DateTime @default(now())
}

model Order {
  id          String      @id @default(cuid())
  ref         String      @unique
  email       String
  name        String
  address     String
  houseNumber String?
  city        String
  postalCode  String
  country     String
  subtotal     Float?
  discount     Float       @default(0)
  couponCode   String?
  shippingCost Float        @default(0)
  total       Float
  // pending_payment | paid | processing | shipped | delivered | cancelled | failed | expired
  status      String      @default("pending_payment")
  locale      String      @default("en")
  items       OrderItem[]

  // Payment (Mollie)
  paymentId     String?
  paymentStatus String?
  paidAt        DateTime?

  // Shipping (Sendcloud)
  shippingMethod    String?
  sendcloudParcelId String?
  trackingNumber    String?
  trackingUrl       String?
  labelUrl          String?

  createdAt   DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  productId String
  name      String
  price     Float
  qty       Int
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  price       Float
  salePrice   Float?
  category    String
  image       String
  badge       String?
  stock       Int      @default(0)
  material    Json
  dimensions  String
  layerHeight String
  finishing   Json
  name        Json
  description Json
  // SEO (localized JSON: { en, nl, fr })
  metaTitle       Json?
  metaDescription Json?
  imageAlt        Json?
  modelUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/* Singleton store configuration — one row, id = "store". */
model StoreSetting {
  id                    String   @id @default("store")
  storeName             String   @default("Loboratorium")
  currency              String   @default("EUR")
  vatRate               Float    @default(21) // percent, prices are VAT-inclusive
  shippingFlatRate      Float    @default(6.5)
  freeShippingThreshold Float?   @default(150)
  shippingRates         Json? // per-country overrides, e.g. { "NL": 8.5, "FR": 9 }
  checkoutEnabled       Boolean  @default(true)
  updatedAt             DateTime @updatedAt
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  type      String    @default("percent") // "percent" | "fixed"
  value     Float
  minOrder  Float?
  maxUses   Int?
  usedCount Int       @default(0)
  expiresAt DateTime?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
}
