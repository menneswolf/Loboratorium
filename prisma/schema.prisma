// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  projectType String
  quantity    String?
  budget      String?
  message     String
  fileUrl     String?
  createdAt   DateTime @default(now())
}
